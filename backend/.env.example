# ===== 项目配置 =====
PROJECT_NAME=EnterpriseKB
VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# ===== API配置 =====
HOST=0.0.0.0
PORT=8000
WORKERS=4
SHOW_DOCS=True

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/enterprisekb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===== Redis配置 =====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ===== Milvus配置 =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=enterprise_documents
MILVUS_DIMENSION=1024

# ===== Meilisearch配置 =====
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_INDEX_NAME=documents_bm25
MEILISEARCH_API_KEY=

# ===== LLM配置 (vLLM) =====
LLM_API_URL=http://localhost:8000/v1
LLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1

# ===== Embedding配置 =====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# ===== Reranker配置 =====
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_K=15

# ===== JWT配置 =====
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 企业微信配置 =====
WECHAT_CORP_ID=
WECHAT_APP_SECRET=
WECHAT_APP_ID=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# ===== MinIO配置 =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_NAME=enterprisekb-docs

# ===== RabbitMQ配置 =====
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ===== 文档处理配置 =====
MAX_FILE_SIZE=52428800
CHUNK_SIZE=512
CHUNK_OVERLAP=50
